\newlabel{app:trim_other}{{F}{15}{}{section.F}{}}
\newlabel{app:trim_other@cref}{{[section][6][]F}{[1][15][]15}{}{}{}}
\newlabel{tab:layer_type}{{8}{16}{Layer-type attribution of TACT's gain on \emph {both} ViT-B/32 and ViT-B/16 ($k=0.5$, mean of 3 fine-tuning seeds). Starting from the ACTMat baseline (\emph {none}), magnitude-trim is applied to the data-free covariance estimator $\hat C_t$ for the indicated group of layers only; remaining layers retain the raw $\hat C_t=\Delta _t^\top \Delta _t$. \textbf {The TACT gain is overwhelmingly an MLP-block phenomenon on both architectures}: on B/32 \texttt {all\_mlp} recovers $96\%$ of the full TACT gain ($+2.16$ of $+2.26$); on B/16 \texttt {all\_mlp} recovers $92\%$ ($+1.01$ of $+1.10$)}{table.caption.17}{}}
\newlabel{tab:layer_type@cref}{{[table][8][]8}{[1][14][]16}{}{}{}}
\newlabel{fig:layer_type}{{9}{16}{Per-group accuracy gain (vs.\ ACTMat) from selectively applying TACT trim to each layer type, on \emph {both} ViT-B/32 (left) and ViT-B/16 (right). Bars show 3-seed mean $\pm $ std. The MLP block (orange) carries essentially all of the gain on both architectures}{figure.caption.18}{}}
\newlabel{fig:layer_type@cref}{{[figure][9][]9}{[1][14][]16}{}{}{}}
\newlabel{tab:trim_other}{{9}{17}{Generality of magnitude trim across data-free merging methods. For each method, we apply identical TIES-style magnitude trim with keep fraction $k$ to each $\Delta _t$ before running the method (3-seed mean $\pm $ std, all 7 tasks). Reported is the best of $k\in \{0.3, 0.5\}$. Only ACTMat's covariance solve benefits substantially on both architectures; for the spectral method Iso-C the same trim \emph {hurts}. The TACT improvement is therefore specific to interference-minimizing covariance solves, not a generic side-effect of trimming}{table.caption.19}{}}
\newlabel{tab:trim_other@cref}{{[table][9][]9}{[1][15][]17}{}{}{}}
