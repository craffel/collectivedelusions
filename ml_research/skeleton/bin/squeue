#!/bin/bash
# Wrapper around squeue that restricts output to this agent's tagged jobs.
# Any caller-supplied flags are passed through, but a --jobs=<own-ids> filter is appended.
set -euo pipefail

: "${AGENT_ID:?AGENT_ID env var must be set by the sandbox}"
REAL_BIN="${REAL_SLURM_BIN:-/run/slurm-real/bin}"
REAL_SQUEUE="$REAL_BIN/squeue"
TAG="agent-${AGENT_ID}"

# Collect this agent's job IDs by tag.
mapfile -t ours < <("$REAL_SQUEUE" --me -h -o '%i %k' | awk -v tag="$TAG" '$2==tag { print $1 }')

if [[ ${#ours[@]} -eq 0 ]]; then
    # No tagged jobs: show empty result (header only, if any) by asking for a non-existent ID.
    # Slurm prints just the header and exits 0 when --jobs lists only unknown IDs (with a stderr warning we suppress).
    exec "$REAL_SQUEUE" --jobs=4294967295 "$@" 2>/dev/null
fi

ids=$(IFS=,; echo "${ours[*]}")
exec "$REAL_SQUEUE" --jobs="$ids" "$@"
