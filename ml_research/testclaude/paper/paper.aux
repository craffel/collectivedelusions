\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {Task-routing diagnostic.} For each task $t$ and each of the 37 linear layers in the visual encoder, we form the routing matrix $P_t(k) = \hat  C_t(k)(\DOTSB \sum@ \slimits@ _s \hat  C_s(k) + \rho \bar  \lambda I)^{-1}$ and measure what fraction of its Frobenius mass is concentrated on task-$t$'s active columns (top-$10\%$ of per-column $\|\Delta _t\|$). \textbf  {(a)}\nobreakspace  {}As the keep-fraction $k$ decreases, the on-target mass \emph  {grows} and the off-target mass \emph  {shrinks} relative to the uniform-routing null baseline of $0.1$. \textbf  {(b)}\nobreakspace  {}The on/off ratio rises from $1.24$ at $k{=}1$ (ACTMat) to $1.42$ at $k{=}0.3$ (SCALE default) to $2.24$ at $k{=}0.05$---a direct measure of how much more task-specific each $P_t$ becomes. This is what SCALE-Merge's ``cleaner covariances'' are doing, in the only sense that the RegMean solve cares about.}}{11}{figure.5}\protected@file@percent }
\newlabel{fig:routing}{{5}{11}{\textbf {Task-routing diagnostic.} For each task $t$ and each of the 37 linear layers in the visual encoder, we form the routing matrix $P_t(k) = \hat C_t(k)(\sum _s \hat C_s(k) + \rho \bar \lambda I)^{-1}$ and measure what fraction of its Frobenius mass is concentrated on task-$t$'s active columns (top-$10\%$ of per-column $\|\Delta _t\|$). \textbf {(a)}~As the keep-fraction $k$ decreases, the on-target mass \emph {grows} and the off-target mass \emph {shrinks} relative to the uniform-routing null baseline of $0.1$. \textbf {(b)}~The on/off ratio rises from $1.24$ at $k{=}1$ (ACTMat) to $1.42$ at $k{=}0.3$ (SCALE default) to $2.24$ at $k{=}0.05$---a direct measure of how much more task-specific each $P_t$ becomes. This is what SCALE-Merge's ``cleaner covariances'' are doing, in the only sense that the RegMean solve cares about}{figure.5}{}}
